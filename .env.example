# ── Datenbank ──────────────────────────────────────────────────────────────
POSTGRES_DB=projektmanagement
POSTGRES_USER=pm
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+psycopg://pm:change-me-strong-password@db:5432/projektmanagement

# ── Verschlüsselung (32 Bytes, Base64) ───────────────────────────────────────
# Erzeugen: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_MASTER_KEY=

# ── Auth / Sessions ─────────────────────────────────────────────────────────
# Erzeugen: python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=

# Session-Laufzeit in Sekunden (Standard: 8 h)
SESSION_TTL_SEC=28800

# Argon2id / PBKDF2
PBKDF2_ITERATIONS=600000

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Origin des Frontends im Browser (nur ein Eintrag, keine IP in .env.example)
CORS_ORIGINS=http://localhost:3000

# ── Multi-Tenant (später SaaS) ──────────────────────────────────────────────
# Leer = Single-Tenant Self-Host
DEFAULT_TENANT_SLUG=default

# Registrierung über API erlauben (Self-Host: meist false, Admin per Script)
ALLOW_REGISTRATION=false

# Cookies: COOKIE_SECURE=true hinter HTTPS in Produktion
COOKIE_SECURE=false
